# Copy this file to .env. Never commit .env.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=langgraph-coder
OLLAMA_NUM_CTX=32768
OLLAMA_TEMPERATURE=0.2
OLLAMA_WRITER_NUM_PREDICT=512

# Keep the full agent on Ollama by default. Set to groq only for a fast demo run.
FULL_AGENT_MODEL_PROVIDER=ollama
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_MAX_TOKENS=2048

# Keep cloud tracing and paid-provider integrations off by default.
LANGSMITH_TRACING=false
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=deep-research-with-langgraph
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_WORKSPACE_ID=

# Research agent search. Tavily matches the original course setup.
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
TAVILY_INCLUDE_ANSWER=false
TAVILY_INCLUDE_RAW_CONTENT=false
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
